# Required: OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Single-account mode: set GH_TOKEN directly
# Scopes needed: repo, read:org, notifications
GH_TOKEN=

# Multi-account mode: define each account's token in its own env var.
# The names here must match the token_env values in the accounts section of config.yml.
# GH_TOKEN_PERSONAL=
# GH_TOKEN_ORG=

# Optional: set to "true" to skip git push and PR creation (safe for local testing)
AGENT_DRY_RUN=false

# Email notifications (Gmail SMTP)
# EMAIL_APP_PASSWORD: generate at https://myaccount.google.com/apppasswords
EMAIL_FROM=you@gmail.com
EMAIL_APP_PASSWORD=
EMAIL_TO=you@gmail.com
